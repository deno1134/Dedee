{
  "name": "denicord-backend",
  "version": "1.0.0",
  "description": "Denicord Discord Clone Backend Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "build": "echo 'No build step needed for backend'",
    "postinstall": "npm run db:migrate",
    "db:migrate": "if [ \"$NODE_ENV\" = \"production\" ]; then psql $DATABASE_URL -f database/schema.sql; fi",
    "db:seed": "if [ \"$NODE_ENV\" = \"production\" ]; then psql $DATABASE_URL -f database/seed.sql; fi",
    "health": "curl -f http://localhost:$PORT/api/health || exit 1"
  },
  "keywords": [
    "discord",
    "clone",
    "chat",
    "messaging",
    "voice",
    "video",
    "nodejs",
    "socket.io",
    "postgresql"
  ],
  "author": "Denicord Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.1",
    "node-webrtc": "^0.4.7",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/denicord/denicord.git"
  },
  "bugs": {
    "url": "https://github.com/denicord/denicord/issues"
  },
  "homepage": "https://denicord.com"
}